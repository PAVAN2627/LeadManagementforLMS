{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "installCommand": "npm install",
    "functions": {
        "api/index.ts": {
            "maxDuration": 10
        }
    },
    "crons": [
        {
            "path": "/api/cron/send-reminders",
            "schedule": "0 9 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/.*).*)",
            "destination": "/index.html"
        }
    ]
}