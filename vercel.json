{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "installCommand": "npm install",
    "crons": [
        {
            "path": "/api/cron/send-reminders",
            "schedule": "0 9 * * *"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}